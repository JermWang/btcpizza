# BTC Pizza Day local environment.
# Copy to `.env`. Do not commit real secrets or keypair files.

# ---------------------------------------------------------------------------
# Server / admin
# ---------------------------------------------------------------------------
PORT=4199
# Required on Vercel/live. The admin page will not unlock without one of these.
ADMIN_PASSWORD=
ADMIN_API_TOKEN=
ADMIN_STORAGE_PATH=./.admin-data
# Optional but recommended for production. When set, admin manifests, batches,
# receipts, and audit logs are stored in Postgres instead of local files.
DATABASE_URL=

# ---------------------------------------------------------------------------
# Solana RPC
# ---------------------------------------------------------------------------
SOLANA_CLUSTER=mainnet-beta
# Use a dedicated mainnet RPC for launch. Helius is recommended for holder scans.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
SOLANA_RPC_RETRY_COUNT=4
SOLANA_RPC_RETRY_BASE_MS=650
PUBLIC_SOLSCAN_BASE_URL=https://solscan.io
PUBLIC_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# ---------------------------------------------------------------------------
# Public project addresses
# ---------------------------------------------------------------------------
# These are public addresses only. Keep private keys out of env files.
DEV_CREATOR_WALLET=6fPPxdyfwqvJSvn9dqa8x7TeFd7P8yQPeUWSQSBbLVvE
PUBLIC_TOKEN_MINT=ATyQWLEfSgBR3Fepj8D1k8RdyxERagnFiwsyMvbpump
PUBLIC_CONTRACT_ADDRESS=ATyQWLEfSgBR3Fepj8D1k8RdyxERagnFiwsyMvbpump
PUBLIC_FEE_WALLET=6fPPxdyfwqvJSvn9dqa8x7TeFd7P8yQPeUWSQSBbLVvE
PUBLIC_DISTRIBUTOR_WALLET=6fPPxdyfwqvJSvn9dqa8x7TeFd7P8yQPeUWSQSBbLVvE
CREATOR_PUBLIC_KEY=6fPPxdyfwqvJSvn9dqa8x7TeFd7P8yQPeUWSQSBbLVvE
JUPITER_SWAP_USER_PUBLIC_KEY=6fPPxdyfwqvJSvn9dqa8x7TeFd7P8yQPeUWSQSBbLVvE

# Solana wrapped assets.
PUBLIC_WBTC_MINT=9n4nbM75f5Ui33ZbPYXn59EwSgE8CGsHtAeTH5YFeJ9E
PUBLIC_WSOL_MINT=So11111111111111111111111111111111111111112

# ---------------------------------------------------------------------------
# Local signing
# ---------------------------------------------------------------------------
# Use local keypair file paths. Do not paste private keys into chat.
CREATOR_KEYPAIR_PATH=
DISTRIBUTOR_KEYPAIR_PATH=
JUPITER_SWAP_KEYPAIR_PATH=

# Keep these true until every dry-run button works.
CREATOR_FEE_DRY_RUN=true
DISTRIBUTOR_DRY_RUN=true

# ---------------------------------------------------------------------------
# Creator-fee claim
# ---------------------------------------------------------------------------
PUMPPORTAL_LOCAL_API_URL=https://pumpportal.fun/api/trade-local
CREATOR_FEE_POOL=pump
CREATOR_FEE_PRIORITY_FEE_SOL=0.000001
FEE_RECEIPT_LIMIT=10

# ---------------------------------------------------------------------------
# Jupiter SOL/WSOL -> Solana WBTC
# ---------------------------------------------------------------------------
JUPITER_API_BASE_URL=https://api.jup.ag/swap/v1
JUPITER_API_KEY=
JUPITER_INPUT_MINT=So11111111111111111111111111111111111111112
JUPITER_INPUT_SOURCE=sol
JUPITER_WRAP_AND_UNWRAP_SOL=true
MAX_CYCLE_SPEND_UI_AMOUNT=0.01
MAX_SLIPPAGE_BPS=100

# ---------------------------------------------------------------------------
# Holder snapshots and WBTC airdrops
# ---------------------------------------------------------------------------
# Use live onchain holder discovery. Helius pagination avoids public RPC scan limits.
HOLDER_SNAPSHOT_PROVIDER=helius
ENABLE_RPC_HOLDER_FALLBACK=true
HOLDER_INDEXER_API_URL=
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_TOKEN_ACCOUNT_PAGE_SIZE=1000
HELIUS_TOKEN_ACCOUNT_MAX_PAGES=1000
HOLDER_SNAPSHOT_MIN_BALANCE=0
HOLDER_MAX_SUPPLY_PERCENT=20
HOLDER_EXCLUDED_POOL_WALLETS=
HOLDER_ROUND_CAP=128
HOLDER_EXCLUDED_WALLETS=6fPPxdyfwqvJSvn9dqa8x7TeFd7P8yQPeUWSQSBbLVvE

# Optional display/schedule timestamp only. It does not execute launch actions.
# Keep blank until you intentionally set it after the manual admin launch.
PUBLIC_DISTRIBUTION_STARTED_AT=
PUBLIC_DISTRIBUTION_MODE=exponential
PUBLIC_DISTRIBUTION_BASE_INTERVAL_SECONDS=180
PUBLIC_DISTRIBUTION_INTERVAL_MULTIPLIER=2
PUBLIC_DISTRIBUTION_BASE_HOLDER_CAP=128
PUBLIC_DISTRIBUTION_HOLDER_CAP_MULTIPLIER=2
PUBLIC_DISTRIBUTION_PREVIEW_EPOCHS=12

MIN_AIRDROP_UI_AMOUNT=0.000001
CREATE_RECIPIENT_ATAS=true
MAX_RECIPIENTS_PER_BATCH=4

# ---------------------------------------------------------------------------
# Devnet smoke test
# ---------------------------------------------------------------------------
DEVNET_RPC_URL=https://api.devnet.solana.com
DEVNET_DISTRIBUTOR_KEYPAIR_PATH=./.admin-data/devnet-test/distributor.json
DEVNET_MIN_DISTRIBUTOR_LAMPORTS=100000000
DEVNET_AIRDROP_RECIPIENTS=3

# ---------------------------------------------------------------------------
# Optional webhook overrides
# ---------------------------------------------------------------------------
# Most admin actions run inside this repo. Set a shared webhook only if you
# intentionally want an external keeper/distributor to override an action.
ADMIN_ACTION_WEBHOOK_URL=
ADMIN_ACTION_WEBHOOK_SECRET=
ADMIN_WEBHOOK_TIMEOUT_MS=60000
