# BTC Pizza Day environment template.
# Copy to `.env` for the local preview/server. Do not commit real secrets.

# ---------------------------------------------------------------------------
# Public web/runtime config
# ---------------------------------------------------------------------------
PORT=4173
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
PUBLIC_SOLSCAN_BASE_URL=https://solscan.io
PUBLIC_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Public project addresses. These are safe to expose, but must be real before launch.
PUBLIC_FEE_WALLET=
PUBLIC_DISTRIBUTOR_WALLET=
PUBLIC_TOKEN_MINT=
PUBLIC_WBTC_MINT=9n4nbM75f5Ui33ZbPYXn59EwSgE8CGsHtAeTH5YFeJ9E

# Optional holder snapshot/indexer endpoint.
# Expected response shape:
# {
#   "configured": true,
#   "roundCap": 128,
#   "cutoffScore": 38500,
#   "eligibleCount": 128,
#   "updatedAt": "2026-05-19T00:00:00.000Z",
#   "current": {
#     "wallet": "...",
#     "rank": 1,
#     "score": 123,
#     "cutoffScore": 100,
#     "cutoffDelta": 23,
#     "cutoffProgress": 91,
#     "estimatedWbtc": 0.00001,
#     "oddsLabel": "Top 10%",
#     "status": "eligible"
#   },
#   "holders": []
# }
HOLDER_INDEXER_API_URL=

# Fee receipt polling
FEE_RECEIPT_LIMIT=10

# ---------------------------------------------------------------------------
# Keeper / distributor secrets
# ---------------------------------------------------------------------------
# Use paths or managed signer references. Never paste private-key arrays into env.
KEEPER_KEYPAIR_PATH=
DISTRIBUTOR_KEYPAIR_PATH=
KEEPER_DRY_RUN=true
DISTRIBUTOR_DRY_RUN=true

# Swap / airdrop controls
AIRDROP_INTERVAL_SCHEDULE_SECONDS=180,300,600,900,1800,3600,7200,14400,28800,43200,86400
AIRDROP_REPEAT_FINAL_INTERVAL=true
MAX_SLIPPAGE_BPS=100
MAX_CYCLE_SPEND_UI_AMOUNT=
MIN_AIRDROP_UI_AMOUNT=
CREATE_RECIPIENT_ATAS=true
MAX_RECIPIENTS_PER_BATCH=12

# Indexer storage
DATABASE_URL=postgres://postgres:postgres@localhost:5432/btc_pizza_day
SNAPSHOT_STORAGE_PATH=./snapshots
MANIFEST_STORAGE_PATH=./manifests

# Optional custody/login provider. Leave blank if tracking the fee wallet directly.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
