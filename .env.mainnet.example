# BTC Pizza Day mainnet deployment environment.
# Copy these names into your Vercel project env vars. Do not commit real secrets.

# ---------------------------------------------------------------------------
# Required admin auth
# ---------------------------------------------------------------------------
ADMIN_PASSWORD=
ADMIN_API_TOKEN=
ADMIN_STORAGE_PATH=./.admin-data

# ---------------------------------------------------------------------------
# Solana mainnet
# ---------------------------------------------------------------------------
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
SOLANA_RPC_RETRY_COUNT=4
SOLANA_RPC_RETRY_BASE_MS=650
PUBLIC_SOLSCAN_BASE_URL=https://solscan.io
PUBLIC_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# ---------------------------------------------------------------------------
# Project addresses
# ---------------------------------------------------------------------------
# Set DEV_CREATOR_WALLET to the creator/dev wallet public key. Wallet-specific
# values can stay blank if every role uses the same creator wallet.
DEV_CREATOR_WALLET=
PUBLIC_FEE_WALLET=
PUBLIC_DISTRIBUTOR_WALLET=
CREATOR_PUBLIC_KEY=
JUPITER_SWAP_USER_PUBLIC_KEY=
PUBLIC_TOKEN_MINT=
PUBLIC_CONTRACT_ADDRESS=

# Solana wrapped assets.
PUBLIC_WBTC_MINT=9n4nbM75f5Ui33ZbPYXn59EwSgE8CGsHtAeTH5YFeJ9E
PUBLIC_WSOL_MINT=So11111111111111111111111111111111111111112

# ---------------------------------------------------------------------------
# Signing
# ---------------------------------------------------------------------------
# Prefer keypair file paths for local ops. For serverless live ops, keep dry-run
# enabled until you intentionally design secure key custody for live signing.
CREATOR_KEYPAIR_PATH=
DISTRIBUTOR_KEYPAIR_PATH=
JUPITER_SWAP_KEYPAIR_PATH=
CREATOR_FEE_DRY_RUN=true
DISTRIBUTOR_DRY_RUN=true

# ---------------------------------------------------------------------------
# Creator-fee claim
# ---------------------------------------------------------------------------
PUMPPORTAL_LOCAL_API_URL=https://pumpportal.fun/api/trade-local
CREATOR_FEE_POOL=pump
CREATOR_FEE_PRIORITY_FEE_SOL=0.000001
FEE_RECEIPT_LIMIT=10

# ---------------------------------------------------------------------------
# Jupiter SOL/WSOL -> Solana WBTC
# ---------------------------------------------------------------------------
JUPITER_API_BASE_URL=https://api.jup.ag/swap/v1
JUPITER_API_KEY=
JUPITER_INPUT_MINT=So11111111111111111111111111111111111111112
JUPITER_INPUT_SOURCE=sol
JUPITER_WRAP_AND_UNWRAP_SOL=true
MAX_CYCLE_SPEND_UI_AMOUNT=0.01
MAX_SLIPPAGE_BPS=100

# ---------------------------------------------------------------------------
# Holder snapshots and WBTC airdrops
# ---------------------------------------------------------------------------
HOLDER_SNAPSHOT_PROVIDER=solana-rpc
ENABLE_RPC_HOLDER_FALLBACK=true
HOLDER_INDEXER_API_URL=
HOLDER_SNAPSHOT_MIN_BALANCE=0
HOLDER_ROUND_CAP=128
HOLDER_EXCLUDED_WALLETS=

# Use the token launch timestamp so every visitor sees the same epoch.
PUBLIC_DISTRIBUTION_STARTED_AT=
PUBLIC_DISTRIBUTION_MODE=exponential
PUBLIC_DISTRIBUTION_BASE_INTERVAL_SECONDS=180
PUBLIC_DISTRIBUTION_INTERVAL_MULTIPLIER=2
PUBLIC_DISTRIBUTION_BASE_HOLDER_CAP=128
PUBLIC_DISTRIBUTION_HOLDER_CAP_MULTIPLIER=2
PUBLIC_DISTRIBUTION_PREVIEW_EPOCHS=12

MIN_AIRDROP_UI_AMOUNT=0.000001
CREATE_RECIPIENT_ATAS=true
MAX_RECIPIENTS_PER_BATCH=4

# ---------------------------------------------------------------------------
# Optional webhook overrides
# ---------------------------------------------------------------------------
ADMIN_ACTION_WEBHOOK_URL=
ADMIN_ACTION_WEBHOOK_SECRET=
ADMIN_WEBHOOK_TIMEOUT_MS=60000
